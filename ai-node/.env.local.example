# --- Native Provider Keys (ALWAYS preferred when present & working) ---
# Routing is native-first: whenever a class has a working native key, calls go
# directly to that provider. OpenRouter (below) is used ONLY for classes without
# a working native key.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
HYPERBOLIC_API_KEY=

# --- OpenRouter (optional — fallback for providers without a working native key) ---
# Adds ~5% fee on top of standard token costs. Setting this does NOT override
# native keys: native is still used whenever it is available and working.
OPENROUTER_API_KEY=

# --- Gateway Override Controls (optional) ---
# Global override. Leave UNSET for the native-first default.
# AI_GATEWAY=native       # force all classes to native keys only
# AI_GATEWAY=openrouter   # override native-first: force all classes through OpenRouter

# Per-class overrides (take precedence over the global setting).
# NOTE: these are auto-managed by the installer's key-validation step — a class
# whose native key is failing is pinned to OpenRouter here until a working key is
# added. You normally don't need to edit these by hand.
# OPENAI_CLASS_PROVIDER=openrouter
# ANTHROPIC_CLASS_PROVIDER=openrouter
# XAI_CLASS_PROVIDER=openrouter
# HYPERBOLIC_CLASS_PROVIDER=openrouter

# Per-class model override (OpenRouter or native)
# OPENAI_CLASS_MODEL=openai/gpt-4o
# ANTHROPIC_CLASS_MODEL=anthropic/claude-3-5-sonnet-20241022
# XAI_CLASS_MODEL=x-ai/grok-4-0709
# HYPERBOLIC_CLASS_MODEL=meta-llama/llama-3.3-70b-instruct

# Deprecated / no-op: native-first is now the default, so this flag has no effect.
# AI_GATEWAY_LEGACY_NATIVE_FALLBACK=false

# --- App Settings ---
JUSTIFIER_MODEL=OpenAI:gpt-5-nano-2025-08-07
REASONING_MODEL_MAX_TOKENS=16000
MODEL_TIMEOUT_MS=120000
REQUEST_TIMEOUT_MS=240000

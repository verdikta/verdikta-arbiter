# --- Native Provider Keys (preferred, no markup) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
HYPERBOLIC_API_KEY=

# --- OpenRouter (optional — covers providers you don't have native keys for) ---
# Adds ~5% fee on top of standard token costs
OPENROUTER_API_KEY=

# --- Gateway Override Controls (optional) ---
# AI_GATEWAY=native       # force all classes to native keys only
# AI_GATEWAY=openrouter   # force all classes through OpenRouter

# Per-class overrides (take precedence over global setting)
# OPENAI_CLASS_PROVIDER=native
# ANTHROPIC_CLASS_PROVIDER=openrouter
# XAI_CLASS_PROVIDER=native
# HYPERBOLIC_CLASS_PROVIDER=native

# Per-class model override (OpenRouter or native)
# OPENAI_CLASS_MODEL=openai/gpt-4o
# ANTHROPIC_CLASS_MODEL=anthropic/claude-3-5-sonnet-20241022
# XAI_CLASS_MODEL=x-ai/grok-4-0709
# HYPERBOLIC_CLASS_MODEL=meta-llama/llama-3.3-70b-instruct

# Legacy compatibility opt-in
# AI_GATEWAY_LEGACY_NATIVE_FALLBACK=false

# --- App Settings ---
JUSTIFIER_MODEL=OpenAI:gpt-5-nano-2025-08-07
REASONING_MODEL_MAX_TOKENS=16000
MODEL_TIMEOUT_MS=120000
REQUEST_TIMEOUT_MS=240000
